{
  "name": "acr-next-sanity",
  "version": "2.0.0",
  "description": "Schema UI: Next.js + Sanity Starter Template",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:frontend": "pnpm run dev --workspace=frontend",
    "dev:studio": "pnpm run dev --workspace=studio",
    "typegen": "cd studio && pnpm typegen",
    "typecheck": "cd frontend && pnpm typecheck",
    "export": "cd studio && sanity dataset export production sample-data.tar.gz"
  },
  "packageManager": "pnpm@10.19.0",
  "homepage": "https://www.schemaui.com/"
}